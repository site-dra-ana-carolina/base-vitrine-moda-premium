modules = ["nodejs-24"]
run = "pnpm dev"

[deployment]
router = "application"
deploymentTarget = "autoscale"
build = ["pnpm", "build"]
run = ["pnpm", "preview", "--", "--port", "8080"]

[workflows]
runButton = "Project"

[[ports]]
localPort = 5173
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080
